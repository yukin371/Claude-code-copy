{
  "name": "neko-code",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "build:native": "bun build --compile src/entrypoints/cli.tsx --outfile dist/neko-code.exe",
    "build:local-release-bundle": "bun run scripts/build-local-release-bundle.ts",
    "stage:release-candidate": "bun run scripts/stage-release-candidate.ts",
    "stage:release-publication": "bun run scripts/stage-release-publication.ts",
    "stage:release-deploy": "bun run scripts/stage-release-deploy.ts",
    "stage:native-installer": "bun run scripts/stage-native-installer.ts",
    "stage:github-release": "bun run scripts/stage-github-release.ts",
    "release:apply-signed-artifact": "bun run scripts/apply-signed-release-artifact.ts",
    "release:deploy-publish": "bun run scripts/release-deploy-publish.ts",
    "release:promote-github-release": "bun run scripts/promote-github-release.ts",
    "start": "bun src/entrypoints/cli.tsx",
    "start:version": "bun src/entrypoints/cli.tsx --version",
    "start:help": "bun src/entrypoints/cli.tsx --help",
    "start:help:no-serena": "cmd /d /s /c \"set NEKO_CODE_DISABLED_MCP_SERVERS=serena && bun src/entrypoints/cli.tsx --help\"",
    "start:doctor-help:no-serena": "cmd /d /s /c \"set NEKO_CODE_DISABLED_MCP_SERVERS=serena && bun src/entrypoints/cli.tsx doctor --help\"",
    "start:install-help:no-serena": "cmd /d /s /c \"set NEKO_CODE_DISABLED_MCP_SERVERS=serena && bun src/entrypoints/cli.tsx install --help\"",
    "start:provider-help": "bun src/entrypoints/cli.tsx --provider gemini --help",
    "start:provider-help:no-serena": "cmd /d /s /c \"set NEKO_CODE_DISABLED_MCP_SERVERS=serena && bun src/entrypoints/cli.tsx --provider gemini --help\"",
    "start:model-provider-help": "bun src/entrypoints/cli.tsx --model sonnet --provider gemini --help",
    "start:model-provider-help:no-serena": "cmd /d /s /c \"set NEKO_CODE_DISABLED_MCP_SERVERS=serena && bun src/entrypoints/cli.tsx --model sonnet --provider gemini --help\"",
    "start:update-help:no-serena": "cmd /d /s /c \"set NEKO_CODE_DISABLED_MCP_SERVERS=serena && bun src/entrypoints/cli.tsx update --help\"",
    "analyze:text-hygiene": "bun run scripts/analyze-text-hygiene.ts",
    "check:docs": "powershell -ExecutionPolicy Bypass -File scripts/check-docs.ps1",
    "check:text-hygiene": "bun run scripts/check-text-hygiene.ts",
    "install:local-launcher": "powershell -ExecutionPolicy Bypass -File scripts/install-local-launcher.ps1",
    "install:local-beta": "powershell -ExecutionPolicy Bypass -File scripts/install-local-beta-installer.ps1",
    "smoke:claude-config": "bun run scripts/claude-config-smoke.ts",
    "smoke:claude-config:no-serena": "bun run scripts/claude-config-smoke.ts --disable-serena",
    "smoke:headless-print-liveness": "bun run scripts/headless-print-liveness-smoke.ts",
    "smoke:mcp-state": "bun run scripts/mcp-state-smoke.ts",
    "smoke:readonly-routing": "powershell -ExecutionPolicy Bypass -File scripts/readonly-smoke.ps1 -Workflow routing",
    "smoke:readonly-routing:no-serena": "powershell -ExecutionPolicy Bypass -File scripts/readonly-smoke.ps1 -Workflow routing -DisableSerena",
    "smoke:session-continue": "bun run scripts/session-continue-smoke.ts",
    "smoke:session-continue:no-serena": "bun run scripts/session-continue-smoke.ts --disable-serena",
    "smoke:session-resume": "bun run scripts/session-resume-smoke.ts",
    "smoke:session-resume-worktree": "bun run scripts/session-resume-worktree-smoke.ts",
    "smoke:session-resume-worktree:no-serena": "bun run scripts/session-resume-worktree-smoke.ts --disable-serena",
    "smoke:plugin-install": "bun run scripts/plugin-install-smoke.ts",
    "smoke:plugin-refresh": "bun run scripts/plugin-refresh-smoke.ts",
    "smoke:plugin-cli-state": "bun run scripts/plugin-cli-state-smoke.ts",
    "smoke:plugin-cli-state:no-serena": "bun run scripts/plugin-cli-state-smoke.ts --disable-serena",
    "smoke:lsp-refresh": "bun run scripts/lsp-refresh-smoke.ts",
    "smoke:mcp-strict-config": "bun run scripts/mcp-strict-config-smoke.ts",
    "smoke:context-compact": "bun run scripts/context-compact-smoke.ts",
    "smoke:context-compact:no-serena": "bun run scripts/context-compact-smoke.ts --disable-serena",
    "smoke:native-distribution": "bun run scripts/native-distribution-smoke.ts",
    "smoke:native-distribution:no-serena": "bun run scripts/native-distribution-smoke.ts --disable-serena",
    "smoke:native-local-install": "bun run scripts/native-local-install-smoke.ts",
    "smoke:native-local-install:no-serena": "bun run scripts/native-local-install-smoke.ts --disable-serena",
    "smoke:native-installer-local-bundle": "bun run scripts/native-installer-local-bundle-smoke.ts",
    "smoke:native-installer-release-publication": "bun run scripts/native-installer-release-publication-smoke.ts",
    "smoke:stage-native-installer": "bun run scripts/stage-native-installer-smoke.ts",
    "smoke:apply-signed-release-artifact": "bun run scripts/apply-signed-release-artifact-smoke.ts",
    "smoke:stage-github-release": "bun run scripts/stage-github-release-smoke.ts",
    "smoke:publish-github-release": "bun run scripts/publish-github-release-smoke.ts",
    "smoke:signed-release-publication-workflow": "bun run scripts/signed-release-publication-workflow-smoke.ts",
    "smoke:promote-github-release": "bun run scripts/promote-github-release-smoke.ts",
    "smoke:stage-release-deploy": "bun run scripts/stage-release-deploy-smoke.ts",
    "smoke:release-deploy-publish": "bun run scripts/release-deploy-publish-smoke.ts",
    "smoke:native-update-cli-release-deploy": "bun run scripts/native-update-cli-release-deploy-smoke.ts",
    "smoke:native-update-cli-github-release": "bun run scripts/native-update-cli-github-release-smoke.ts",
    "smoke:release-facing-diagnostics": "bun run scripts/release-facing-diagnostics-smoke.ts",
    "smoke:distribution-readiness": "bun run scripts/distribution-readiness-smoke.ts",
    "smoke:release-preflight": "bun run scripts/release-preflight.ts",
    "smoke:plugin-state": "bun run scripts/plugin-state-smoke.ts",
    "smoke:migrated-config-system": "bun run scripts/migrated-config-system-smoke.ts",
    "smoke:phase3-system-regression": "bun run scripts/phase3-system-regression-smoke.ts",
    "test:routing": "bun test src/services/api/openaiCompatibleClient.test.ts src/utils/promptCategory.test.ts src/utils/model/taskRouting.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
